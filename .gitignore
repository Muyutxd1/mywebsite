# Python
__pycache__/
*.pyc
.env
venv/
.venv/
*.egg-info/

# Runtime-generated share files
backend/data/shares/

# Local data backups
*.old
*.bak
*.premerge

# Problem-bank: the read-only SQLite DB + served images ARE committed so the
# Render deploy needs no rebuild (git pull = ready). Only transient WAL files
# and the dev-only public/ copy stay ignored.
backend/data/problems.db-wal
backend/data/problems.db-shm
frontend/public/problem-images/
# Enrichment: keep the LLM difficulty/year output (enrichment.jsonl) in git —
# it is the irreplaceable source the DB build merges; ignore the regenerable bits.
backend/data/enrichment/shards/
backend/data/enrichment/input.jsonl
# Translations: keep the merged zh.jsonl sidecar in git (irreplaceable LLM
# output, keyed by content hash); work shards are regenerable.
backend/data/translations/shards/

# Node / Vite frontend
frontend/node_modules/
frontend/dist/
node_modules/
